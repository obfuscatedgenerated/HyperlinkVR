{
    "$schema": "https://unpkg.com/knip@6/schema.json",
    "workspaces": {
        ".": {
            "ignoreDependencies": ["wxt"]
        },
        "apps/extension": {
            "entry": [
                "src/entrypoints/background.ts",
                "src/entrypoints/*.content.ts",
                "src/entrypoints/**/main.tsx"
            ],
            "ignore": "src/shims/**/*.ts",
            "project": ["src/**/*.{ts,tsx}", "wxt.config.ts"]
        },
        "packages/*": {
            "entry": "src/index.{ts,tsx}!",
            "project": "src/**/*.{ts,tsx}!"
        },
        "scripts": {
            "entry": "build_json_schema.ts",
            "project": ["build_json_schema.ts"]
        }
    }
}
